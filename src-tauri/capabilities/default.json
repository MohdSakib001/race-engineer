{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Apex Engineer",
  "windows": ["main", "driver-*", "page-*", "overlay"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:webview:default",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:scope-appdata-recursive",
    "fs:scope-document-recursive",
    "shell:default",
    "shell:allow-open",
    "log:default"
  ]
}
